generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String @id @default(uuid())
  username      String @unique
  passwordHash  String
  createdAt     DateTime @default(now())
}

model Message {
  id        String   @id @default(uuid())
  sender    String
  content   String
  tone      String
  createdAt DateTime @default(now())
}
